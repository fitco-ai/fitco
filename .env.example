# ==========================================
# 🗄️ 백엔드 / 데이터베이스
# ==========================================
# 데이터베이스 연결 문자열 (필수)
DATABASE_URL="postgresql://user:password@localhost:5432/fitco"

# ==========================================
# 🔐 인증 및 보안
# ==========================================
# NextAuth 서명용 암호화 키 (필수, `openssl rand -base64 32` 등으로 생성)
NEXTAUTH_SECRET="your_nextauth_secret_here"

# 위젯 인증을 위한 JWT 시크릿 (필수)
WIDGET_JWT_SECRET="your_widget_jwt_secret_here"

# 추천 ID 해시 생성용 솔트 (필수)
RECOMMENDATION_ID_HASH_SALT="your_recommendation_salt_here"

# 쇼핑몰 ID 해시 생성용 솔트 (필수)
MALL_ID_HASH_SALT="your_mall_id_salt_here"

# ==========================================
# 🛒 Cafe24 연동
# ==========================================
# Cafe24 앱 클라이언트 ID (클라이언트 노출, 필수)
NEXT_PUBLIC_CAFE24_CLIENT_ID="your_cafe24_client_id_here"

# Cafe24 앱 리다이렉트 URI (클라이언트 노출, 필수)
NEXT_PUBLIC_CAFE24_REDIRECT_URI="http://localhost:3000/api/auth/callback/cafe24"

# Cafe24 권한 범위(Scope) (클라이언트 노출, 필수)
NEXT_PUBLIC_CAFE24_SCOPE="mall.read_product,mall.read_order"

# Cafe24 API 시크릿 키 (필수)
CAFE24_SECRET_KEY="your_cafe24_secret_key_here"

# Cafe24 API 버전 (필수)
CAFE24_API_VERSION="2023-09-01"

# ==========================================
# ☁️ 네이버 클라우드 & 메시징 (SMS, 알림톡)
# ==========================================
# 네이버 클라우드 Access Key (필수)
NAVER_CLOUD_ACCESS_KEY_ID="your_naver_access_key_here"

# 네이버 클라우드 Secret Key (필수)
NAVER_CLOUD_SECRET_KEY="your_naver_secret_key_here"

# 네이버 SENS (SMS 연동) 서비스 ID (필수)
NAVER_SENS_SERVICE_ID="your_naver_sens_service_id_here"

# 문자/알림톡 발신 전화번호 (필수)
NAVER_SENS_CALLING_PHONE="01012345678"

# 뿌리오(Ppurio) 발송 API 키 (필수)
PPURIO_API_KEY="your_ppurio_api_key_here"

# ==========================================
# 📧 이메일 및 외부 API (OpenAI 등)
# ==========================================
# Resend 발신자 이메일 주소 (이메일 형식, 필수)
RESEND_FROM="onboarding@resend.dev"

# Resend API 토큰 ('re_'로 시작, 필수)
RESEND_TOKEN="re_123456789"

# OpenAI API 연동 키 (필수)
OPEN_AI_API_KEY="sk-your_openai_api_key_here"

# ==========================================
# 🌐 공통 및 애널리틱스
# ==========================================
# ngrok 등 외부 접속 가능한 사이트 URL (클라이언트 노출, 필수)
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# 위젯 스크립트 소스 경로 (클라이언트 노출, 필수)
NEXT_PUBLIC_WIDGET_SRC="http://localhost:3000/widget.js"

# 구글 애널리틱스 추적 ID ('G-'로 시작, 선택사항)
NEXT_PUBLIC_GA_MEASUREMENT_ID="G-1234567890"

# Next.js 번들 사이즈 분석 모드 활성화 여부 (선택사항, 'true' 등)
ANALYZE="false"
